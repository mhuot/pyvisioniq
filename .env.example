# Hyundai/Kia Connect API credentials
BLUELINKUSER=your_email@example.com
BLUELINKPASS=your_password
BLUELINKPIN=1234
BLUELINKREGION=3  # 1=Europe, 2=Canada, 3=USA, 4=China, 5=Australia
BLUELINKBRAND=2   # 1=Kia, 2=Hyundai, 3=Genesis
BLUELINKVID=YOUR_VEHICLE_ID

# App settings
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
API_CACHE_ENABLED=true
CACHE_DURATION_HOURS=24  # How long to cache API responses
PORT=5000
API_DAILY_LIMIT=30  # Maximum API calls per day
TZ=America/Chicago  # Timezone (Minnesota is Central Time)
DEBUG_MODE=false  # Set to true for verbose logging and debug features

# Data is stored as CSV files in the ./data directory.

# Authentication (Microsoft Entra ID / OIDC). Optional — off by default.
# When AUTH_ENABLED=false, all routes are public and the AZURE_* vars are ignored.
AUTH_ENABLED=false
# AZURE_CLIENT_ID=your-app-registration-client-id
# AZURE_CLIENT_SECRET=your-app-registration-client-secret
# AZURE_TENANT_ID=your-directory-tenant-id
# AZURE_REDIRECT_URI=https://your-host/auth/callback  # must match the app registration
# FLASK_SECRET_KEY=change-me  # signs session cookies; required when auth is enabled
# ADMIN_USERS=admin@example.com,other@example.com  # emails allowed on admin/debug routes
# SESSION_FILE_DIR=sessions  # server-side session store (must be writable)

# Nginx proxy settings (for nginx-proxy-network)
VIRTUAL_HOST=pyvisionic.example.com  # Your domain name
VIRTUAL_PORT=5000  # Should match PORT above
LETSENCRYPT_HOST=pyvisionic.example.com  # For SSL certificate (optional)
LETSENCRYPT_EMAIL=your_email@example.com  # For SSL certificate notifications (optional)